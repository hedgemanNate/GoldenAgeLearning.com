{
  "rules": {
    "users": {
      ".read": "auth != null && (auth.token.role == 'staff' || auth.token.role == 'superAdmin')",
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || auth.token.role == 'staff' || auth.token.role == 'superAdmin')",
        ".write": "auth != null && (auth.uid == $uid || auth.token.role == 'superAdmin')"
      }
    },
    "classes": {
      ".read": true,
      "$classId": {
        ".write": "auth != null && (auth.token.role == 'staff' || auth.token.role == 'superAdmin')"
      }
    },
    "bookings": {
      ".read": "auth != null && (auth.token.role == 'staff' || auth.token.role == 'superAdmin')",
      "$bookingId": {
        ".read": "auth != null && (data.child('customerId').val() == auth.uid || auth.token.role == 'staff' || auth.token.role == 'superAdmin')",
        ".write": false
      }
    },
    "transferLog": {
      "$transferId": {
        ".read": "auth != null && (auth.token.role == 'staff' || auth.token.role == 'superAdmin')",
        ".write": false
      }
    },
    "discounts": {
      ".read": "auth != null && (auth.token.role == 'staff' || auth.token.role == 'superAdmin')",
      "$discountId": {
        ".read": "data.child('status').val() == 'active' || (auth != null && (auth.token.role == 'staff' || auth.token.role == 'superAdmin'))",
        ".write": "auth != null && (auth.token.role == 'superAdmin' || (auth.token.role == 'sponsor' && data.child('sponsorId').val() == auth.uid))"
      }
    },
    "messages": {
      ".read": "auth != null && (auth.token.role == 'staff' || auth.token.role == 'superAdmin')",
      "$messageId": {
        ".read": "auth != null && (auth.token.role == 'staff' || auth.token.role == 'superAdmin' || data.child('recipients').hasChild(auth.uid))",
        ".write": "auth != null && (auth.token.role == 'staff' || auth.token.role == 'superAdmin')"
      }
    },
    "activityLog": {
      "$logId": {
        ".read": "auth != null && auth.token.role == 'superAdmin'",
        ".write": false
      }
    },
    "payments": {
      "$paymentId": {
        ".read": "auth != null && (data.child('customerId').val() == auth.uid || auth.token.role == 'staff' || auth.token.role == 'superAdmin')",
        ".write": false
      }
    }
  }
}

